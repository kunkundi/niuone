# Copy this file to dashboard.env for local production-style runs.
# Keep dashboard.env private; it may contain secrets and absolute local paths.

DASHBOARD_HOME=/absolute/path/to/NiuOne/.local-data/runtime
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787
PYTHON_BIN=python3

# The dashboard stays public; settings and admin APIs always require authentication.
# Leave blank to use the bootstrap key at $DASHBOARD_HOME/dashboard_admin_token.txt.
DASHBOARD_ADMIN_PASSWORD=

DASHBOARD_CONFIG=/absolute/path/to/NiuOne/.local-data/runtime/config.yaml
DASHBOARD_PUSH_HISTORY_DB=/absolute/path/to/NiuOne/.local-data/runtime/push_history.db
DASHBOARD_PORTFOLIO_STATE=/absolute/path/to/NiuOne/.local-data/runtime/cron/output/niuniu_practice_portfolio.json
DASHBOARD_TRADER_SCRIPT=/absolute/path/to/NiuOne/app/entrypoints/niuniu_practice_trader.py

DASHBOARD_EDGE_CACHE_ENABLED=0
DASHBOARD_RATE_LIMIT_ENABLED=1
DASHBOARD_RATE_LIMIT_ANON=240
DASHBOARD_RATE_LIMIT_API=900
DASHBOARD_RATE_LIMIT_ADMIN=90

# Candidate scans and model decisions run inside the Dashboard process.
# Automatic exit checks run through the separate Cron Scheduler process.
DASHBOARD_B1_SCHEDULE_ENABLED=1
DASHBOARD_B1_SCHEDULE_TIMES=09:25,10:00,10:30,11:00,11:20,13:00,13:30,14:00,14:30,14:50
DASHBOARD_B1_SCHEDULE_CATCHUP_MINUTES=35
DASHBOARD_B1_SCHEDULE_STALE_SECONDS=900
DASHBOARD_B1_SCAN_TIMEOUT_SECONDS=360
DASHBOARD_B3_EXIT_TIME=09:37
DASHBOARD_TIME_EXIT_TIME=14:45
# base | zettaranc | li_daxiao_bottom | sector_tide | preset_text
DASHBOARD_ACTIVE_STRATEGY=zettaranc
DASHBOARD_PRESET_STRATEGY_TEXT=
DASHBOARD_STOCK_UNIVERSE=main_board
DASHBOARD_TRADE_DISCIPLINE_TEXT=
# Length defaults: context windows use 128000 tokens, max output uses 4096 tokens.
DASHBOARD_DECISION_CONTEXT_LENGTH=128000
DASHBOARD_DECISION_MAX_TOKENS=4096
DASHBOARD_DECISION_TIMEOUT=180
DASHBOARD_DECISION_INTELLIGENCE_ENABLED=1
DASHBOARD_DECISION_INTELLIGENCE_TTL_SECONDS=75
DASHBOARD_DECISION_INTELLIGENCE_MAX_ITEMS=5
DASHBOARD_MAX_OPEN_POSITIONS=6
DASHBOARD_MAX_NEW_BUYS_PER_DECISION=2
DASHBOARD_MAX_SINGLE_POSITION_PCT=10
DASHBOARD_MAX_TOTAL_POSITION_PCT=80
DASHBOARD_MIN_CASH_RESERVE_PCT=20
DASHBOARD_MARKET_GUIDANCE_ENABLED=1
DASHBOARD_MORNING_MAX_OPEN_POSITIONS=3

# Trade notifications are disabled by default. Enable the master switch and
# each configured channel. Webhooks, signing secrets, and bot tokens are private.
DASHBOARD_NOTIFICATION_ENABLED=0
DASHBOARD_NOTIFICATION_TIMEOUT_SECONDS=5
DASHBOARD_FEISHU_NOTIFICATION_ENABLED=0
DASHBOARD_FEISHU_WEBHOOK_URL=
DASHBOARD_FEISHU_SIGNING_SECRET=
DASHBOARD_DINGTALK_NOTIFICATION_ENABLED=0
DASHBOARD_DINGTALK_WEBHOOK_URL=
DASHBOARD_DINGTALK_SIGNING_SECRET=
DASHBOARD_WECOM_NOTIFICATION_ENABLED=0
DASHBOARD_WECOM_WEBHOOK_URL=
DASHBOARD_TELEGRAM_NOTIFICATION_ENABLED=0
DASHBOARD_TELEGRAM_BOT_TOKEN=
DASHBOARD_TELEGRAM_CHAT_ID=

DASHBOARD_US_FEATURES_ENABLED=0
DASHBOARD_GROK_MODEL=grok-4.20-multi-agent-xhigh
# auto: Grok 4.5 uses Responses search tools; responses/chat force either API.
DASHBOARD_GROK_API_MODE=auto
DASHBOARD_GROK_CONTEXT_LENGTH=128000
DASHBOARD_GROK_MAX_TOKENS=4096
DASHBOARD_GROK_BASE_URL=
DASHBOARD_GROK_API_KEY=
US_RATING_CONTEXT_LENGTH=128000
US_RATING_MAX_TOKENS=4096
DASHBOARD_NEWS_MODEL=
# auto: Grok 4.5/GPT-5 search models use Responses; responses/chat force either API.
DASHBOARD_NEWS_API_MODE=auto
DASHBOARD_NEWS_CONTEXT_LENGTH=128000
DASHBOARD_NEWS_MAX_TOKENS=4096
DASHBOARD_NEWS_BASE_URL=
DASHBOARD_NEWS_API_KEY=
DASHBOARD_NEWS_TIMEOUT=45
DASHBOARD_NEWS_MAX_RETRIES=1
DASHBOARD_NEWS_CONCURRENCY=5

# Built-in iWencai data source (disabled by default).
IWENCAI_ENABLED=0
IWENCAI_BASE_URL=https://openapi.iwencai.com
IWENCAI_API_KEY=
IWENCAI_TIMEOUT_SECONDS=20
IWENCAI_MAX_RETRIES=1
IWENCAI_MAX_CONCURRENCY=2
IWENCAI_CACHE_TTL_SECONDS=300
IWENCAI_DRAGON_TIGER_CRON="0 18 * * 1-5"

DASHBOARD_DECISION_MODEL=deepseek-v4-pro

DASHBOARD_US_MARKET_SUMMARY_CRON="0 8 * * 1-5"
US_MARKET_SUMMARY_CONTEXT_LENGTH=128000
US_MARKET_SUMMARY_MAX_TOKENS=4096
DASHBOARD_MARKET_AUCTION_CRON="25 9 * * 1-5"
DASHBOARD_MARKET_MIDDAY_CRON="40 11 * * 1-5"
DASHBOARD_MARKET_CLOSE_CRON="10 15 * * 1-5"
DASHBOARD_CRON_MAX_ATTEMPTS=2
DASHBOARD_CRON_RETRY_DELAY_SECONDS=300
A_SHARE_AUCTION_SNAPSHOT_MIN_ROWS=4000
A_SHARE_SUMMARY_SPOT_MIN_ROWS=4000
A_SHARE_SUMMARY_SPOT_MIN_BSE_ROWS=100
A_SHARE_SUMMARY_TENCENT_DEADLINE=25
A_SHARE_SUMMARY_LIMIT_POOL_TIMEOUT=8
A_SHARE_MIDDAY_MAX_QUOTE_AGE_MINUTES=20
A_SHARE_MODEL_SUMMARY_ENABLED=1
A_SHARE_MODEL_SUMMARY_MODEL=
A_SHARE_MODEL_SUMMARY_CONTEXT_LENGTH=128000
A_SHARE_MODEL_SUMMARY_MAX_TOKENS=4096
A_SHARE_MODEL_SUMMARY_BASE_URL=
A_SHARE_MODEL_SUMMARY_API_KEY=
A_SHARE_MODEL_SUMMARY_DEADLINE_SECONDS=60
A_SHARE_MODEL_SUMMARY_REQUEST_TIMEOUT_SECONDS=45
X_WATCHLIST_CONTEXT_LENGTH=128000
X_WATCHLIST_MAX_TOKENS=4096
X_WATCHLIST_DAEMON_INTERVAL_SECONDS=1200
X_WATCHLIST_REQUEST_TIMEOUT_SECONDS=45
DASHBOARD_US_RATING_CRON="0 11 * * *"
DASHBOARD_INDICES_TTL_SECONDS=60
